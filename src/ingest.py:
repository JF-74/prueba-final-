import duckdb
import pandas as pd
import os

def run_ingest():
    csv_file = 'data/Superstore.csv'
    
    
    if not os.path.exists(csv_file):
        print(f"Error: No se encontró el archivo en {csv_file}")
        return

    
    con = duckdb.connect('dbt/dbt_test.duckdb')
    
    
    df = pd.read_csv(csv_file)
    con.execute("CREATE OR REPLACE TABLE raw_superstore AS SELECT * FROM df")
    
    print("Ingesta exitosa: Tabla 'raw_superstore' creada en DuckDB.")
    con.close()

if __name__ == "__main__":
    run_ingest()
